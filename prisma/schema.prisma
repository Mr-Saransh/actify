// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  level     Int      @default(1) // 1: Inactive, 2: Active, 3: Consistent, 4: Executor, 5: Operator
  points    Int      @default(0)
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals Goal[]
}

model Goal {
  id          String     @id @default(uuid())
  userId      String
  title       String
  description String?
  type        GoalType
  deadline    DateTime
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]
}

model Task {
  id        String    @id @default(uuid())
  goalId    String
  title     String // Auto-generated or templated
  description String? // Detailed instructions
  hints     String? // Optional hint for the user
  date      DateTime
  deadline  DateTime?
  dayIndex  Int // Day 1, Day 2, etc.
  state     TaskState @default(LOCKED)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  goal  Goal   @relation(fields: [goalId], references: [id])
  proof Proof?
}

model Proof {
  id           String      @id @default(uuid())
  taskId       String      @unique
  content      String // URL or text content
  explanation  String
  submittedAt  DateTime    @default(now())
  reviewStatus ReviewStatus @default(PENDING)
  aiFeedback   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  task Task @relation(fields: [taskId], references: [id])
}

enum GoalType {
  PROJECT
  SKILL
  EXAM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  ARCHIVED
}

enum TaskState {
  LOCKED
  ACTIVE
  SUBMITTED
  ACCEPTED
  REJECTED
  FAILED
}

enum ReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}
