// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  level     Int      @default(1) // 1: Inactive, 2: Active, 3: Consistent, 4: Executor, 5: Operator
  points    Int      @default(0) // Legacy: Keeping for safety, but migrating to actPoints
  streak    Int      @default(0)
  
  // -- Dual-Currency System --
  actPoints        Int      @default(0) // Reputation (Leaderboard)
  actCurrency      Int      @default(0) // Spendable (Store)

  // -- Stats --
  tasksCompleted   Int      @default(0)
  failures         Int      @default(0)
  goalsCompleted   Int      @default(0)
  
  // -- Daily Tracking (New) --
  lastCompletionDate  DateTime?  // Last date a task was accepted
  lastFailureCheck    DateTime?  // Last time we checked for missed days
  dailyTaskCompleted  Boolean   @default(false) // Has completed task today?
  
  // -- Inventory --
  freezeActCount   Int      @default(0)
  beyondActCount   Int      @default(0)
  
  // -- Profile --
  name             String?
  image            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals              Goal[]
  marketplaceItems   MarketplaceListing[]
  sentMessages       Message[] @relation("SentMessages")
  receivedMessages   Message[] @relation("ReceivedMessages")
}

model Goal {
  id              String     @id @default(uuid())
  userId          String
  title           String
  description     String?
  category        String     @default("Custom")
  type            GoalType?
  timePerDay      Int        @default(60)
  experienceLevel String     @default("Beginner")
  deadline        DateTime

  // AI Mission Blueprint Data
  estimatedHours  Int        @default(0)
  difficulty      String     @default("Medium")
  successProbability Int     @default(50)
  commitment      String     @default("Standard")
  risks           String[]

  status          GoalStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  tasks       Task[]
  milestones  Milestone[]
}

model Task {
  id        String    @id @default(uuid())
  goalId    String
  title          String // Auto-generated or templated
  description    String? // Detailed instructions
  hints          String? // Optional hint for the user
  
  // AI Execution Engine Fields
  milestoneId    String?
  objective      String?
  expectedOutput String?
  resources      String[]
  estimatedTime  Int?    // In minutes
  difficulty     String?
  date      DateTime
  deadline  DateTime?
  dayIndex  Int // Day 1, Day 2, etc.
  state     TaskState @default(LOCKED)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  goal  Goal   @relation(fields: [goalId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  proof Proof?
}

model Milestone {
  id          String   @id @default(uuid())
  goalId      String
  title       String
  description String?
  order       Int
  duration    Int?     // estimated duration in hours
  difficulty  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal        Goal     @relation(fields: [goalId], references: [id])
  tasks       Task[]
}

model Proof {
  id           String      @id @default(uuid())
  taskId       String      @unique
  content      String // URL or text content
  imageUrl     String? // Optional Proof Image (Base64/URL)
  explanation  String
  
  // Validation Metadata
  validationType String? // e.g. "QUIZ", "CODE_REVIEW", "GRAMMAR", "METRICS"
  quizSeed       Int?
  quizPromptHash String?
  
  submittedAt  DateTime    @default(now())
  reviewStatus ReviewStatus @default(PENDING)
  aiFeedback   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  task Task @relation(fields: [taskId], references: [id])
}

enum GoalType {
  PROJECT
  SKILL
  EXAM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  ARCHIVED
}

enum TaskState {
  LOCKED
  ACTIVE
  SUBMITTED
  ACCEPTED
  REJECTED
  FAILED
}

enum ReviewStatus {
  PENDING
  PENDING_QUIZ
  ACCEPTED
  REJECTED
}

model MarketplaceListing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Int      // Price in ACT Currency
  category    String   @default("RESOURCE") // JOURNEY, RESOURCE, TEMPLATE, PRODUCT
  imageUrl    String?  // Cloudinary URL
  journeyData Json?    // Snapshot of verified journey
  sellerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller      User     @relation(fields: [sellerId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
